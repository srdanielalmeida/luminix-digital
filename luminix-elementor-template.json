                            "settings": {
                                "html": "\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"primary\": \"#1152d4\",\n                        \"background-light\": \"#f6f6f8\",\n                        \"background-dark\": \"#101622\",\n                    },\n                    fontFamily: {\n                        \"display\": [\"Manrope\", \"sans-serif\"]\n                    },\n                    borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n                },\n            },\n        }\n    </script>\n<style>\n        body { font-family: 'Manrope', sans-serif; }\n        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }\n    </style>\n\n<div class=\"bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display\">\n\n<!-- Top Navigation Bar -->\n<header class=\"sticky top-0 z-50 bg-white/80 dark:bg-background-dark/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"flex items-center justify-between h-16 sm:h-20\">\n<div class=\"flex items-center gap-2\">\n<div class=\"text-primary\">\n<svg class=\"w-8 h-8\" fill=\"none\" viewbox=\"0 0 48 48\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z\" fill=\"currentColor\"></path>\n</svg>\n</div>\n<span class=\"text-xl font-extrabold tracking-tight\">Luminix<span class=\"text-primary\">.digital</span></span>\n</div>\n<nav class=\"hidden md:flex items-center gap-8\">\n<a class=\"text-sm font-semibold hover:text-primary transition-colors\" href=\"#inicio\">Início</a>\n<a class=\"text-sm font-semibold hover:text-primary transition-colors\" href=\"#escolher\">Diferenciais</a>\n<a class=\"text-sm font-semibold hover:text-primary transition-colors\" href=\"#beneficios\">Benefícios</a>\n<a class=\"text-sm font-semibold hover:text-primary transition-colors\" href=\"#depoimentos\">Depoimentos</a>\n</nav>\n<button class=\"bg-primary text-white px-6 py-2.5 rounded-full text-sm font-bold shadow-lg shadow-primary/20 hover:scale-105 transition-transform\">\n                    Comprar Agora\n                </button>\n</div>\n</div>\n</header>\n<!-- Hero Section -->\n<section class=\"relative overflow-hidden pt-12 pb-20 lg:pt-20 lg:pb-32\" id=\"inicio\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"lg:flex lg:items-center lg:gap-16\">\n<div class=\"flex-1 text-center lg:text-left\">\n<span class=\"inline-block px-4 py-1.5 mb-6 text-xs font-bold uppercase tracking-widest text-primary bg-primary/10 rounded-full\">\n                        Inovação em Bem-Estar\n                    </span>\n<h1 class=\"text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-tight mb-6\">\n                        Descubra o Conforto e o Bem-Estar com Nossa <span class=\"text-primary\">Massageadora Ortopédica!</span>\n</h1>\n<p class=\"text-lg sm:text-xl text-slate-600 dark:text-slate-400 mb-10 max-w-2xl mx-auto lg:mx-0\">\n                        Relaxe e alivie as tensões do dia a dia sem sair de casa com tecnologia de ponta desenvolvida por especialistas.\n                    </p>\n<div class=\"flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4\">\n<button class=\"w-full sm:w-auto px-8 py-4 bg-primary text-white rounded-xl text-lg font-bold shadow-xl shadow-primary/30 hover:bg-primary/90 transition-all\">\n                            Quero minha Massageadora!\n                        </button>\n<div class=\"flex items-center gap-2 text-sm text-slate-500 font-medium\">\n<span class=\"material-symbols-outlined text-green-500\">verified</span>\n                            Frete Grátis para todo o Brasil\n                        </div>\n</div>\n</div>\n<div class=\"flex-1 mt-16 lg:mt-0 relative\">\n<div class=\"absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-primary/5 rounded-full blur-3xl\"></div>\n<div class=\"rounded-3xl overflow-hidden shadow-2xl shadow-primary/10 border-4 border-white dark:border-slate-800 bg-white\">\n<img class=\"w-full h-full object-contain aspect-[4/3] p-4\" alt=\"Produto Massageadora Ortopédica\" src=\"./product.jpg\"/>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Why Choose Section -->\n<section class=\"py-20 bg-white dark:bg-slate-900/50\" id=\"escolher\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"text-center mb-16\">\n<h2 class=\"text-3xl sm:text-4xl font-black mb-4\">Por que escolher?</h2>\n<p class=\"text-slate-600 dark:text-slate-400 max-w-2xl mx-auto\">Tecnologia e design pensados exclusivamente para o seu relaxamento total e recuperação muscular.</p>\n</div>\n<div class=\"grid lg:grid-cols-2 gap-12 items-center\">\n<div class=\"order-2 lg:order-1 grid gap-6\">\n<div class=\"flex gap-5 p-6 rounded-2xl bg-background-light dark:bg-slate-800 border border-slate-100 dark:border-slate-700 hover:border-primary/30 transition-colors\">\n<div class=\"flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined\">accessibility_new</span>\n</div>\n<div>\n<h3 class=\"text-lg font-bold mb-2\">Design Ergonômico</h3>\n<p class=\"text-slate-600 dark:text-slate-400 text-sm leading-relaxed\">Moldado para se ajustar perfeitamente às curvas do seu corpo, garantindo eficácia em cada ponto de pressão.</p>\n</div>\n</div>\n<div class=\"flex gap-5 p-6 rounded-2xl bg-background-light dark:bg-slate-800 border border-slate-100 dark:border-slate-700 hover:border-primary/30 transition-colors\">\n<div class=\"flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined\">memory</span>\n</div>\n<div>\n<h3 class=\"text-lg font-bold mb-2\">Tecnologia Avançada</h3>\n<p class=\"text-slate-600 dark:text-slate-400 text-sm leading-relaxed\">Sistemas de pulsação de última geração com múltiplos níveis de intensidade para um alívio profundo e personalizado.</p>\n</div>\n</div>\n<div class=\"flex gap-5 p-6 rounded-2xl bg-background-light dark:bg-slate-800 border border-slate-100 dark:border-slate-700 hover:border-primary/30 transition-colors\">\n<div class=\"flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined\">diamond</span>\n</div>\n<div>\n<h3 class=\"text-lg font-bold mb-2\">Estilo Sofisticado</h3>\n<p class=\"text-slate-600 dark:text-slate-400 text-sm leading-relaxed\">Acabamento premium em materiais hipoalergênicos que combina com qualquer ambiente da sua casa.</p>\n</div>\n</div>\n</div>\n<div class=\"order-1 lg:order-2\">\n<div class=\"rounded-3xl overflow-hidden shadow-2xl relative group bg-white\">\n<img class=\"w-full h-full object-contain p-4\" alt=\"Massageadora Ortopédica Premium\" src=\"./product.jpg\"/>\n<div class=\"absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\"></div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Benefits Section -->\n<section class=\"py-24\" id=\"beneficios\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n<h2 class=\"text-3xl sm:text-4xl font-black mb-16\">Benefícios Exclusivos</h2>\n<div class=\"grid md:grid-cols-3 gap-8\">\n<div class=\"p-8 rounded-3xl bg-white dark:bg-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-slate-700\">\n<div class=\"w-16 h-16 bg-blue-50 dark:bg-blue-900/20 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary\">\n<span class=\"material-symbols-outlined text-4xl\">bolt</span>\n</div>\n<h3 class=\"text-xl font-bold mb-4\">Alívio Imediato</h3>\n<p class=\"text-slate-600 dark:text-slate-400\">Sinta a tensão desaparecer em minutos. Nossa tecnologia atua diretamente nos nós musculares mais profundos.</p>\n</div>\n<div class=\"p-8 rounded-3xl bg-white dark:bg-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-slate-700\">\n<div class=\"w-16 h-16 bg-blue-50 dark:bg-blue-900/20 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary\">\n<span class=\"material-symbols-outlined text-4xl\">travel_explore</span>\n</div>\n<h3 class=\"text-xl font-bold mb-4\">Praticidade</h3>\n<p class=\"text-slate-600 dark:text-slate-400\">Leve, compacta e sem fios. Leve seu spa pessoal para o escritório, academia ou viagens com total facilidade.</p>\n</div>\n<div class=\"p-8 rounded-3xl bg-white dark:bg-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-slate-700\">\n<div class=\"w-16 h-16 bg-blue-50 dark:bg-blue-900/20 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary\">\n<span class=\"material-symbols-outlined text-4xl\">verified_user</span>\n</div>\n<h3 class=\"text-xl font-bold mb-4\">Durabilidade</h3>\n<p class=\"text-slate-600 dark:text-slate-400\">Construída com polímeros de alta resistência e bateria de longa duração para anos de uso diário contínuo.</p>\n</div>\n</div>\n</div>\n</section>\n<!-- Testimonials Section -->\n<section class=\"py-24 bg-background-light dark:bg-background-dark\" id=\"depoimentos\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"text-center mb-16\">\n<h2 class=\"text-3xl sm:text-4xl font-black mb-4\">O que dizem nossos clientes</h2>\n<div class=\"flex justify-center gap-1\">\n<span class=\"material-symbols-outlined text-yellow-500 fill-current\">star</span>\n<span class=\"material-symbols-outlined text-yellow-500 fill-current\">star</span>\n<span class=\"material-symbols-outlined text-yellow-500 fill-current\">star</span>\n<span class=\"material-symbols-outlined text-yellow-500 fill-current\">star</span>\n<span class=\"material-symbols-outlined text-yellow-500 fill-current\">star</span>\n</div>\n</div>\n<div class=\"grid md:grid-cols-2 gap-8 max-w-4xl mx-auto\">\n<!-- Testimonial 1 -->\n<div class=\"bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-lg border border-slate-100 dark:border-slate-700\">\n<div class=\"flex items-center gap-4 mb-6\">\n<div class=\"w-14 h-14 rounded-full bg-slate-200 overflow-hidden\">\n<img class=\"w-full h-full object-cover\" data-alt=\"Retrato de Ana, cliente satisfeita\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCCqjoM39zFn-Xjr51bXDIb0UrlNojPO3_3Pg7SV9gGywWtnJtSZFdidwNt0UnhtcFBbookSlKXbD9cLJBoAcSIAjHOduToMezXl6yNAj0kz9VwpEjQqoPqIp3nScL8PrCdwqqCFJ9GLm1JGDpyq5AUWaWiBdGCXVDr7d9vavhk5SnJJKHprsvVLOU7k5xLrlzWAVLFschg_aMsN9X4jFXX8Xuqtd7OVz_P6Ih7Zkh7OSLkTy7cccmAQzqhqXr-JfzCUqJKsCdJVO0\"/>\n</div>\n<div>\n<h4 class=\"font-bold\">Ana, 34 anos</h4>\n<p class=\"text-xs text-slate-500 uppercase font-semibold\">Designer Gráfica</p>\n</div>\n</div>\n<p class=\"text-slate-600 dark:text-slate-400 italic leading-relaxed\">\n                        \"Depois de passar o dia todo no computador, minha cervical ficava destruída. A massageadora da Luminix mudou minha rotina. Uso 15 minutos antes de dormir e acordo renovada!\"\n                    </p>\n</div>\n<!-- Testimonial 2 -->\n<div class=\"bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-lg border border-slate-100 dark:border-slate-700\">\n<div class=\"flex items-center gap-4 mb-6\">\n<div class=\"w-14 h-14 rounded-full bg-slate-200 overflow-hidden\">\n<img class=\"w-full h-full object-cover\" data-alt=\"Retrato de Lucas, cliente satisfeito\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAWlpDkCq_3L6TyQS8TYFcUvMoDj0OOJ--F4djJl0SbgNRHU_-dLSNArYi50DXCDUgIFrkKaoxd_0ibFn-DJmui2ert0mIK_XLO_n0IpLvqCaW6c1Qd6miIiyBGFQy3YdbdaRGZWBY0qIw3UjUVR6qEObHQGA5bcu8VlffNLpOSPdoCJal4sep2-9gNHVZjS8_QL0sijapMpdownnij8vQVPr2z9xmFuVIhG8jJTomu2Ysb7RZOZDE_waVU240w0Ggm3iu6t6JGSMs\"/>\n</div>\n<div>\n<h4 class=\"font-bold\">Lucas, 28 anos</h4>\n<p class=\"text-xs text-slate-500 uppercase font-semibold\">Atleta Amador</p>\n</div>\n</div>\n<p class=\"text-slate-600 dark:text-slate-400 italic leading-relaxed\">\n                        \"Minha recuperação muscular pós-treino melhorou significativamente. É impressionante como a pressão é precisa e realmente relaxa as fibras musculares. Vale cada centavo.\"\n                    </p>\n</div>\n</div>\n</div>\n</section>\n<!-- Final CTA Section -->\n<section class=\"py-20\">\n<div class=\"max-w-5xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"bg-primary rounded-[2.5rem] p-8 sm:p-16 text-center text-white relative overflow-hidden\">\n<div class=\"absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-64 h-64 bg-white/10 rounded-full blur-3xl\"></div>\n<div class=\"absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-64 h-64 bg-white/10 rounded-full blur-3xl\"></div>\n<h2 class=\"text-3xl sm:text-5xl font-black mb-6 relative z-10\">Oferta por Tempo Limitado!</h2>\n<p class=\"text-lg sm:text-xl text-blue-100 mb-10 max-w-2xl mx-auto relative z-10\">\n                    Garanta sua Massageadora Ortopédica hoje com 30% de desconto e frete grátis. Não deixe seu bem-estar para amanhã.\n                </p>\n<button class=\"bg-white text-primary px-10 py-5 rounded-2xl text-xl font-black shadow-2xl hover:scale-105 transition-transform relative z-10\">\n                    QUERO MINHA MASSAGEADORA AGORA!\n                </button>\n<div class=\"mt-8 flex items-center justify-center gap-6 text-sm font-bold text-blue-100 relative z-10\">\n<div class=\"flex items-center gap-1\">\n<span class=\"material-symbols-outlined text-sm\">lock</span>\n                        Compra Segura\n                    </div>\n<div class=\"flex items-center gap-1\">\n<span class=\"material-symbols-outlined text-sm\">sync</span>\n                        7 Dias de Garantia\n                    </div>\n</div>\n</div>\n</div>\n</section>\n<!-- Footer -->\n<footer class=\"bg-white dark:bg-background-dark border-t border-slate-200 dark:border-slate-800 py-12\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"flex flex-col md:flex-row justify-between items-center gap-8\">\n<div class=\"flex items-center gap-2\">\n<div class=\"text-primary\">\n<svg class=\"w-6 h-6\" fill=\"none\" viewbox=\"0 0 48 48\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z\" fill=\"currentColor\"></path>\n</svg>\n</div>\n<span class=\"text-lg font-extrabold tracking-tight\">Luminix<span class=\"text-primary\">.digital</span></span>\n</div>\n<div class=\"flex gap-8 text-sm text-slate-500 font-medium\">\n<a class=\"hover:text-primary\" href=\"#\">Políticas de Privacidade</a>\n<a class=\"hover:text-primary\" href=\"#\">Termos de Uso</a>\n<a class=\"hover:text-primary\" href=\"#\">Rastrear Pedido</a>\n</div>\n<div class=\"text-sm text-slate-400\">\n                    © 2024 Luminix.digital. Todos os direitos reservados.\n                </div>\n</div>\n</div>\n</footer>\n\n\n</div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', () => {\n    // Smooth scrolling for navigation links\n    document.querySelectorAll('nav a').forEach(anchor => {\n        anchor.addEventListener('click', function (e) {\n            e.preventDefault();\n            const targetId = this.getAttribute('href').substring(1);\n            const targetElement = document.getElementById(targetId);\n\n            if (targetElement) {\n                targetElement.scrollIntoView({\n                    behavior: 'smooth'\n                });\n            }\n        });\n    });\n\n    // Handle all buttons with text containing \"Comprar\" or \"Quero\"\n    const actionButtons = document.querySelectorAll('button');\n    actionButtons.forEach(button => {\n        const text = button.textContent.toLowerCase();\n        if (text.includes('comprar') || text.includes('quero')) {\n            button.addEventListener('click', () => {\n                window.location.href = 'https://app.coinzz.com.br/checkout/1-unidade-qsndn-0';\n            });\n        }\n    });\n});\n\n</script>\n"
                            },
                            "elements": []
                        }
                    ]
                }
            ]
        }
    ]
}